{
  "name": "asciidoc-zero-network-preview-browser-extension",
  "displayName": "AsciiDoc Zero-Network Preview",
  "version": "0.3.0",
  "description": "Chrome and Edge extension for local AsciiDoc preview with bundled renderers and no external preview services.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/YoshihideShirai/asciidoc-zero-network-preview-browser-extension.git"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && node scripts/build.mjs",
    "package:zip": "npm run build && node scripts/package-extension.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts",
    "verify:no-network": "node scripts/verify-no-network.js",
    "test": "npm run typecheck && npm run build && npm run verify:no-network"
  },
  "dependencies": {
    "@asciidoctor/core": "^3.0.4",
    "@lix-js/html-diff": "^0.1.0",
    "asciidoctor-kroki-embedded": "git+https://github.com/YoshihideShirai/asciidoctor-kroki-embedded.git",
    "asciidoctor-numbered-captions": "git+https://github.com/YoshihideShirai/asciidoctor-numbered-captions.git#v1.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.0",
    "@types/node": "22.x",
    "archiver": "^8.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
